{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "strictNullChecks": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "../json2gbnf/dist",
    "rootDir": "../json2gbnf/src"
  },
  "include": ["../json2gbnf/src/**/*.ts"],
  "exclude": [
    "../json2gbnf/node_modules",
    "../json2gbnf/.vscode-test",
    "../json2gbnf/dist",
    "../json2gbnf/.wireit",
    "../json2gbnf/env",
    "../json2gbnf/src/**/*.test.ts"
  ]
}
