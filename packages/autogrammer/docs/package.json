{
  "name": "@autogrammer/docs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wireit",
    "copy:autogrammer": "wireit",
    "start": "wireit",
    "build": "wireit",
    "serve": "wireit"
  },
  "wireit": {
    "dev": {
      "command": "pnpm start"
    },
    "copy:autogrammer": {
      "command": "mkdir -p ./.docsanova/.staging/js/autogrammer && cp -r ./node_modules/bundled-autogrammer/dist/* ./.docsanova/.staging/js/autogrammer/"
    },
    "start": {
      "command": "pnpm copy:autogrammer && docsanova start --port 8080",
      "dependencies": [
        "../../bundled-autogrammer:build",
        "../../docsanova:build"
      ]
    },
    "build": {
      "command": "pnpm copy:autogrammer && docsanova build --output build",
      "dependencies": [
        "../../bundled-autogrammer:build",
        "../../docsanova:build"
      ]
    },
    "serve": {
      "command": "pnpx serve ./build"
    }
  },
  "dependencies": {
    "@alenaksu/json-viewer": "^2.0.1",
    "@docsearch/css": "^3.6.0",
    "@docsearch/js": "3",
    "@lit/reactive-element": "^2.0.4",
    "@xenova/transformers": "^2.17.1",
    "bundled-autogrammer": "workspace:*",
    "docsanova": "workspace:*",
    "lit": "^3.1.3",
    "lit-element": "^4.0.5",
    "lit-html": "^3.1.3"
  },
  "devDependencies": {
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "wireit": "^0.14.4"
  },
  "packageManager": "pnpm@9.1.4"
}
